{UTF-8}

x from csv = GET DIRECT DATA('data/data.csv', ',', '2', 'D3')
  ~
  ~ This tests the case where there is a NON-NUMERIC cell in the middle of
    other cells.  Vensim omits these data points from the synthesized lookup
    but continues reading other valid data points in the series.
  ~ :SUPPLEMENTARY
  |

x from xlsx = GET DIRECT DATA('data/data.xlsx', 'data', '2', 'D3')
  ~
  ~ This tests the case where there is a NON-NUMERIC cell in the middle of
    other cells.  Vensim omits these data points from the synthesized lookup
    but continues reading other valid data points in the series.
  ~ :SUPPLEMENTARY
  |

y from csv = GET DIRECT DATA('data/data.csv', ',', '2', 'D4')
  ~
  ~ This tests the case where there is a BLANK cell in the middle of
    other cells.  Vensim omits these data points from the synthesized lookup
    but continues reading other valid data points in the series.
  ~ :SUPPLEMENTARY
  |

y from xlsx = GET DIRECT DATA('data/data.xlsx', 'data', '2', 'D4')
  ~
  ~ This tests the case where there is a BLANK cell in the middle of
    other cells.  Vensim omits these data points from the synthesized lookup
    but continues reading other valid data points in the series.
  ~ :SUPPLEMENTARY
  |

x value from csv = x from csv ~~|

x value from xlsx = x from xlsx ~~|

y value from csv = y from csv ~~|

y value from xlsx = y from xlsx ~~|

INITIAL TIME = 2000 ~~|
FINAL TIME = 2002 ~~|
TIME STEP = 1 ~~|
SAVEPER = 1 ~~|
